# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# ── AMZ Navigator: Dify Backend ─────────────────────────────────────────────
# Set these to route all chat traffic through your Dify agent.
# When unset, the app falls back to the AI SDK model gateway.
DIFY_API_BASE_URL=https://<your-dify-host>/v1
DIFY_APP_API_KEY=app-xxxxxxxxxxxxxxxx

# ── AMZ Navigator: Optional Integrations ─────────────────────────────────────────
# Upstash Redis for rate limiting (separate from REDIS_URL if desired)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend for "email me this export" feature
RESEND_API_KEY=
